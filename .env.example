# Railway injects DATABASE_URL automatically once you add the Postgres
# plugin to this project — you don't set this one manually.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Generate your own with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
